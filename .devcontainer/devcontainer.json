{
  "name": "gnc-sim",
  "build": { "dockerfile": "../Dockerfile", "context": ".." },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": "cmake --version && python3 --version && (emcc --version | head -1)"
}
